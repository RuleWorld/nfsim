# Reduced-count TLBR benchmark model for quick NFsim vs RuleMonkey speed checks.

begin parameters

	Lig_tot  20
	Rec_tot  20
	cTot     0.11
	beta     16.8
	koff     0.01

	kp1 (cTot*koff)/(3.0*Lig_tot) #FREE BINDING RATE
	kp2 (beta*koff)/Rec_tot #CROSSLINKING RATE
end parameters

begin molecule types
	L(r,r,r)
	R(l,l)
end molecule types

begin species
	L(r,r,r)	Lig_tot
	R(l,l)		Rec_tot
end species

begin reaction rules
	R(l!1).L(r!1) -> R(l) + L(r) koff
	L(r,r,r) + R(l) -> L(r!1,r,r).R(l!1) kp1
	L(r,r,r!+) + R(l) -> L(r!1,r,r!+).R(l!1) kp2
	L(r,r!+,r!+) + R(l) -> L(r!1,r!+,r!+).R(l!1) kp2
end reaction rules

begin observables
	Molecules Rfree R(l,l)
	Molecules Lfree L(r,r,r)
end observables


writeXML();